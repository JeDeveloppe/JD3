{% extends "site/components/_base.html.twig" %}
{% block title %}Mes articles pour ne plus chercher sur Google !{% endblock %}
{% block body %}

    <h1 class="col-11 text-center mt-5 mx-auto">{{ h1 }}</h1>
    <p class="lead col-11 text-center small fst-italic mx-auto">{{ lead | raw}}</p>

    <div class="row g-0 justify-content-center my-5">

        {% for domain in domains %}
            {# some variables #}
            {% set conjugaisonCategorie = "catégorie" %}
            {% if domains | length > 1 %}
            {% set conjugaisonCategorie = "catégories" %}
            {% endif %}

                <article class="col-6 col-md-4 col-lg-3 col-xxl-2 mb-3">
                    <div class="card col-11 col-sm-10 col-xxl-11 mx-auto">
                    <a href="{{ path('site_my_categories_by_domain', {domainSlug: domain.slug }) }}" class="_card_full_button"></a>
                    <div class="card-header text-center fw-bold">{{ domain.name }}</div>
                    <twig:ux:icon name="{{ domain.renderIconStringWithoutParentheses }}" class="card-img-top p-5 p-md-4"/></twig:ux:icon>
                    <div class="card-footer small text-end fst-italic">{{ domain.categories | length }} {{ conjugaisonCategorie }}</div>
                </article>
        {% endfor %}
    </div>

    {{ knp_pagination_render(domains, 'site/components/_pagination.html.twig') }}

{% endblock %}