<div class="row g-0 justify-content-around mt-5 mb-2">
    <div class="ps-2">
        <nav style="--bs-breadcrumb-divider: '>';" aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <i class="fa-solid fa-road"></i> <a class="text-decoration-none" href="{{ path('site_my_categories') }}">Toutes les astuces</a>
                </li>
                {% if trick is defined %}
                    <li class="breadcrumb-item">
                        <a class="text-decoration-none" href="{{ path('site_my_tricks', {id: category.id, slug: category.slug }) }}">{{ category.name}}</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">{{ trick.name }}</li>
                {% else %}
                    <li class="breadcrumb-item active" aria-current="page">
                        {{ category.name }}
                    </li>
                {% endif %}
            </ol>
        </nav>
    </div>
</div>